# Server runtime
NODE_ENV=production
PORT=3000

# Database
MONGODB_URI=mongodb+srv://username:password@example.mongodb.net/url-shortener
MONGODB_MAX_RETRIES=5
MONGODB_RETRY_DELAY_MS=2000

# Auth and hashing
# Use unique high-entropy values in production. JWT secrets must be at least 32 characters.
JWT_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_TTL_DAYS=7
BCRYPT_SALT_ROUNDS=12
HASH_SALT=replace-with-at-least-16-characters

# Browser and public URL configuration
# CLIENT_URL may be a comma-separated allowlist when multiple frontend origins are deployed.
CLIENT_URL=https://your-frontend.example.com
SHORT_URL_BASE=https://your-short-domain.example.com
VITE_API_URL=https://your-api.example.com
VITE_SHORT_URL_BASE=https://your-short-domain.example.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
